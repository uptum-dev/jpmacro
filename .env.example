# PostgreSQL (TimescaleDB)
DATABASE_URL=postgresql://jpmacro:secret@localhost:5432/jpmacro

# e-Stat API key — ユーザー登録: https://www.e-stat.go.jp/mypage/user/preregister
#                   ID発行ページ: https://www.e-stat.go.jp/api/
ESTAT_API_KEY=your_estat_api_key_here

# x402 payment — Base USDC
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_WALLET_ADDRESS=0xYourBaseWalletAddressHere
# mainnet: base  /  testnet: base-sepolia
X402_NETWORK=base-sepolia

# Server
PORT=3000

# --- Production only (docker-compose.prod.yml) ---
# DB_PASSWORD=strong-random-password-here
